---
import SpeakerSingle from "@components/SpeakerSingle.astro";
import LayoutSpeaker from "@layouts/LayoutSpeaker.astro";
import eventsResponse from "@data/meetups-raw.json";
import speakersResponse from "@data/speakers-raw.json";
import { toSpeakerSlug } from "@utils/helpers";

const props = Astro.params;

export async function getStaticPaths() {
  const speakers = speakersResponse;

  return speakers.map((speaker) => {
    return {
      params: {
        slug: toSpeakerSlug(speaker.name),
      },
    };
  });
}

const getSpeaker = (slug: string) => {
  const speaker = speakersResponse.find((ev) => toSpeakerSlug(ev.name) === slug);

  if (!speaker) {
    console.error("cannot find speaker with slug: ", slug);
    return null;
  }

  // Get sessions of this speaker from the events
  const allSessions = eventsResponse.map((event) => event.sessions).flat();
  const speakerSession = allSessions.filter((session) => {
    let session_speaker_id = session.Session_id.speakers.id;
    return speaker.id === session_speaker_id;
  });

  return {
    person: speaker,
    sessions: speakerSession,
  };
};

const speaker = getSpeaker(props.slug);
---

{
  speaker ? (
    <LayoutSpeaker
      title={speaker.person?.name}
      username={speaker.person?.github_account}
      description="Speaker Profile"
    >
      <SpeakerSingle routeId={props.slug} speaker={speaker} />
    </LayoutSpeaker>
  ) : (
    <div>Speaker not found</div>
  )
}
