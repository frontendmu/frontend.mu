TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
# Generate a new key with: node ace generate:key
APP_KEY=
NODE_ENV=development
SESSION_DRIVER=cookie
APP_URL=http://localhost:3333

# Database (SQLite)
# For local dev with seed data (committed to repo):
DB_DATABASE=database/db.local.sqlite3
# For production (gitignored):
# DB_DATABASE=tmp/db.production.sqlite3

# Feature Flags
FEATURE_RSVP_PAST_EVENTS=false  # Allow users to RSVP to past events
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Drive (file storage)
# DRIVE_DISK=fs uses tmp/uploads/ served at /uploads (dev default).
# DRIVE_DISK=r2 stores files in Cloudflare R2 and serves via CDN_BASE_URL (prod).
DRIVE_DISK=fs
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
CDN_BASE_URL=