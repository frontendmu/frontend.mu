TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
# Generate a new key with: node ace generate:key
APP_KEY=
NODE_ENV=development
SESSION_DRIVER=cookie
APP_URL=http://localhost:3333

# Database (SQLite)
# For local dev with seed data (committed to repo):
DB_DATABASE=database/db.local.sqlite3
# For production (gitignored):
# DB_DATABASE=tmp/db.production.sqlite3

# Feature Flags
FEATURE_RSVP_PAST_EVENTS=false  # Allow users to RSVP to past events
ENABLE_REGISTRATION=false  # Allow email+password sign-up. Off in production (spam control); Google OAuth is the only public signup path.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=