{
  "extends": "@adonisjs/tsconfig/tsconfig.app.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./build",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./inertia/*"],
      "#debug_bar/*": ["./packages/debug-bar/src/*"]
    },
    "types": ["@inertiajs/vue3", "@adonisjs/inertia", "vite/client"]
  },
  "include": ["**/*"],
  "exclude": ["node_modules", "build"]
}
