{
  "extends": "@adonisjs/tsconfig/tsconfig.app.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./build",
    "types": ["@inertiajs/vue3", "@adonisjs/inertia", "vite/client"]
  },
  "references": [{ "path": "./tsconfig.inertia.json" }],
  "include": [
    "./**/*.ts",
    "./**/*.js",
    "./.adonisjs/server/**/*.ts",
    "./.adonisjs/server/**/*.d.ts"
  ],
  "exclude": ["node_modules", "build", "inertia"]
}
